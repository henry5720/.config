  "mcp": {
    "context7": {
      "enabled": true,
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "sequential-thinking": {
      "enabled": true,
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "figma": {
      "enabled": true,
      "type": "local",
      "command": [
        "npx",
        "-y",
        "figma-developer-mcp",
        "--figma-api-key={FIGMA_API_KEY}",
        "--stdio"
      ]
    },
    "chrome-devtools": {
      "enabled": true,
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "environment": {
        "CHROME_DEVTOOLS_MCP_HOST": "localhost",
        "CHROME_DEVTOOLS_MCP_PORT": "9222"
      }
    }
  },
  "plugin": [
    "opencode-wakatime"
  ]
}